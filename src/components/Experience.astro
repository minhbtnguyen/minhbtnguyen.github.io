---

<section class="py-10 border-b border-[#DDD5C8]">
  <div class="flex items-center gap-2 mb-5 justify-center lg:justify-start">
    <div class="w-[3px] h-4 bg-[#CC4400]"></div>
    <span class="text-[14px] font-medium tracking-[0.12em] uppercase text-[#888078]">
      Experience · 2Y FTE · 2Y+ Intern &amp; Research
    </span>
  </div>

  <div class="divide-y divide-[#EEE8E0]">
    {jobs.map((job, i) => (
      <div id={`exp-${job.slug}`} class={`experience-item${job.open ? ' open' : ''}`} style={`--pulse-delay: ${(i % 4) * 0.75}s;`}>
        <!-- Clickable header -->
        <button
          class="experience-toggle w-full flex items-center gap-3 py-4 text-left"
          aria-expanded={job.open ? 'true' : 'false'}
        >
          <!-- Logo / letter square -->
          <div class="logo-box w-10 h-10 shrink-0 relative overflow-hidden">
            <Image
              src={job.logoSrc}
              alt={job.company}
              width={40}
              height={40}
              format="webp"
              loading="eager"
              class="logo-img w-10 h-10 object-contain"
              style="display:none; background:transparent; mix-blend-mode:multiply;"
            />
            <div
              class="logo-fallback w-10 h-10 flex items-center justify-center text-white text-xs font-bold"
              style={`background-color:${job.color};`}
            >
              {job.letter}
            </div>
          </div>
          <!-- Company info -->
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline flex-wrap gap-x-2 mb-0.5">
              <span class="text-[17px] font-semibold tracking-[0.06em] uppercase">{job.company}</span>
              {job.sub && <span class="text-xs text-[#AAA098]">({job.sub})</span>}
              <span class="text-[#CCC5BC] text-xs">·</span>
              <span class="text-[15px] text-[#4A4540] font-light">{job.role}</span>
            </div>
            <div class="flex items-baseline flex-wrap gap-x-2 text-[14px] text-[#888078] font-light">
              <span>{job.period} <span class="text-[#CCC5BC]">({job.duration})</span></span>
              <span class="text-[#CCC5BC]">·</span>
              <span>{job.location}</span>
            </div>
          </div>
          <!-- Chevron -->
          <svg
            class="chevron shrink-0 text-[#AAA098] transition-transform duration-200"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            width="14"
            height="14"
          >
            <polyline points="4,6 8,10 12,6"></polyline>
          </svg>
        </button>

        <!-- Summary always visible -->
        <p class="text-[14px] text-[#888078] font-light leading-relaxed pl-13 pb-3 italic">{job.summary}</p>

        <!-- Expandable content -->
        <div class="experience-content">
          <div class="pb-6 pl-13">
            <ul class="space-y-4">
              {job.bullets.map((bullet) => (
                <li class="pl-3 border-l border-[#DDD5C8]">
                  <p
                    class="text-[15px] text-[#4A4540] leading-[1.7] font-light mb-2"
                    set:html={bullet.text}
                  />
                  <div class="flex flex-wrap gap-1.5">
                    {bullet.tags.map((tag) => (
                      <span class="px-2 py-0.5 text-[11px] font-light bg-[#F0EDE8] text-[#666059] border border-[#E0D8D0] rounded-sm">
                        {tag}
                      </span>
                    ))}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .experience-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  .experience-item.open .experience-content {
    max-height: 2000px;
  }
  .experience-item.open .chevron {
    transform: rotate(180deg);
  }
  .experience-toggle:hover .chevron {
    color: #CC4400;
  }

  @keyframes chevronPulse {
    0%, 100% { color: #AAA098; }
    50%       { color: #CC4400; }
  }

  @keyframes chevronPulseDark {
    0%, 100% { color: #666666; }
    50%       { color: #CC4400; }
  }

  .chevron {
    animation: chevronPulse 3s ease-in-out infinite;
    animation-delay: var(--pulse-delay, 0s);
  }

  :global(html.dark) .chevron {
    animation-name: chevronPulseDark;
  }

  .experience-toggle:hover .chevron,
  .experience-item.open .chevron {
    animation: none;
    color: #CC4400;
  }

  @media (prefers-reduced-motion: reduce) {
    .chevron {
      animation: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.experience-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.experience-item');
      const isOpen = item.classList.contains('open');
      item.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.querySelectorAll('.logo-img').forEach((img) => {
    const fallback = img.nextElementSibling;
    img.addEventListener('load', () => {
      img.style.display = 'block';
      fallback.style.display = 'none';
    });
    img.addEventListener('error', () => {
      img.style.display = 'none';
      fallback.style.display = 'flex';
    });
    if (img.complete && img.naturalWidth > 0) {
      img.style.display = 'block';
      fallback.style.display = 'none';
    }
  });
</script>
