---
---
<section class="pb-10 border-b border-[#DDD5C8]">
  <hr class="border-t border-[#DDD5C8] mb-6" />
  <div class="flex items-center gap-2 mb-3 justify-center lg:justify-start">
    <div class="w-[3px] h-4 bg-[#CC4400]"></div>
    <span class="text-[14px] font-medium tracking-[0.12em] uppercase text-[#888078]">Get in Touch</span>
  </div>
  <p class="text-[18px] text-[#4A4540] font-light mb-5 text-center lg:text-left">
    Cold emails welcome. Fastest reach is direct email.
  </p>
  <div class="flex flex-wrap gap-2.5 justify-center lg:justify-start">
    <!-- Email — orange outline (dark: filled orange) -->
    <a
      href="mailto:minhbtnguyen.work@gmail.com"
      class="contact-email contact-btn flex items-center gap-2 px-4 py-2.5 border border-[#CC4400] bg-white text-[14px] text-[#CC4400]"
    >
      <span class="contact-btn-fill contact-btn-fill--orange"></span>
      <span class="contact-btn-content flex items-center gap-2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        minhbtnguyen.work@gmail.com
      </span>
    </a>
    <!-- GitHub -->
    <a
      href="https://github.com/minhbtnguyen"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn flex items-center gap-2 px-4 py-2.5 border border-[#DDD5C8] bg-white text-[14px] text-[#1A1A1A] hover:border-[#CC4400] transition-colors"
    >
      <span class="contact-btn-fill contact-btn-fill--orange"></span>
      <span class="contact-btn-content flex items-center gap-2">
        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path>
        </svg>
        GitHub
      </span>
    </a>
    <!-- LinkedIn -->
    <a
      href="https://linkedin.com/in/minhbtnguyen"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn flex items-center gap-2 px-4 py-2.5 border border-[#DDD5C8] bg-white text-[14px] text-[#1A1A1A] hover:border-[#CC4400] transition-colors"
    >
      <span class="contact-btn-fill contact-btn-fill--orange"></span>
      <span class="contact-btn-content flex items-center gap-2">
        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
        LinkedIn
      </span>
    </a>
    <!-- Google Scholar -->
    <a
      href="https://scholar.google.com/citations?user=9Pg_ZTgAAAAJ&hl=en"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn flex items-center gap-2 px-4 py-2.5 border border-[#DDD5C8] bg-white text-[14px] text-[#1A1A1A] hover:border-[#CC4400] transition-colors"
    >
      <span class="contact-btn-fill contact-btn-fill--orange"></span>
      <span class="contact-btn-content flex items-center gap-2">
        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
          <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6L23 9 12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/>
        </svg>
        Google Scholar
      </span>
    </a>
  </div>
</section>

<style>
  .contact-btn {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .contact-btn-fill {
    position: absolute;
    inset: 0;
    width: 0%;
    z-index: 0;
    transition: width 0.4s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .contact-btn-fill--orange {
    background-color: #CC4400;
  }

  .contact-btn:hover .contact-btn-fill {
    width: 100%;
  }

  .contact-btn-content {
    position: relative;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .contact-btn:hover .contact-btn-content {
    color: #FFFFFF;
  }
</style>
