---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/ideas', label: "Minh's Ideas" },
  { href: '/distillation', label: 'Distillation' },
];
---

<header class="sticky top-0 z-50 bg-[#FFFDF9]/50 backdrop-blur-md border-b border-[#DDD5C8]/60">
  <div class="max-w-[1280px] mx-auto px-10 h-12 flex items-center justify-between gap-8">

    <!-- Left: logo mark + desktop nav links -->
    <div class="flex items-center gap-6">
      <a href="/" class="shrink-0" aria-label="Home">
        <div class="flex items-center justify-center text-[#1A1A1A] leading-none select-none relative overflow-hidden" style="width:24px;height:30px;border:0.5px solid #C2B8AF;">
          <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-[#CC4400]"></div>
          <span class="relative z-10" style="font-family:'DM Serif Display',Georgia,serif;font-size:16px;font-weight:400;font-style:italic;padding-left:1px;">M</span>
        </div>
      </a>

      <!-- Desktop nav links -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map((link) => {
          const isActive = pathname === link.href;
          return (
            <a
              href={link.href}
              class={`text-[13px] transition-colors ${isActive ? 'font-semibold text-[#CC4400]' : 'font-light text-[#888078] hover:text-[#1A1A1A]'}`}
            >
              {link.label}
            </a>
          );
        })}
      </nav>
    </div>

    <!-- Right -->
    <div class="flex items-center gap-5 shrink-0">

      <!-- Desktop-only: GitHub + LinkedIn + email text -->
      <a
        href="https://github.com/minhbtnguyen"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden lg:block text-[#666059] hover:text-[#CC4400] transition-colors"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://linkedin.com/in/minhbtnguyen"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden lg:block text-[#666059] hover:text-[#CC4400] transition-colors"
        aria-label="LinkedIn"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="mailto:minhbtnguyen.work@gmail.com"
        class="hidden lg:block text-[13px] font-light text-[#666059] hover:text-[#CC4400] transition-colors"
      >
        minhbtnguyen.work@gmail.com
      </a>

      <!-- Mobile-only: email + GitHub + LinkedIn icons -->
      <a
        href="mailto:minhbtnguyen.work@gmail.com"
        class="lg:hidden text-[#666059] hover:text-[#CC4400] transition-colors"
        aria-label="Email"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="17" height="17">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
      <a
        href="https://github.com/minhbtnguyen"
        target="_blank"
        rel="noopener noreferrer"
        class="lg:hidden text-[#666059] hover:text-[#CC4400] transition-colors"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://linkedin.com/in/minhbtnguyen"
        target="_blank"
        rel="noopener noreferrer"
        class="lg:hidden text-[#666059] hover:text-[#CC4400] transition-colors"
        aria-label="LinkedIn"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- Theme toggle — always visible, sits right of email (desktop) and left of hamburger (mobile) -->
      <button
        id="theme-toggle"
        class="text-[#666059] hover:text-[#CC4400] transition-colors flex items-center justify-center"
        aria-label="Toggle dark mode"
      >
        <!-- Moon: shown in light mode -->
        <svg id="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="17" height="17">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun: shown in dark mode -->
        <svg id="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="17" height="17" style="display:none">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <!-- Hamburger — mobile only -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center gap-[5px] w-7 h-7 text-[#666059] hover:text-[#CC4400] transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-5 h-px bg-current transition-all duration-200"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200"></span>
      </button>

    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-[#DDD5C8]/60 bg-[#FFFDF9]/95 backdrop-blur-md"
  >
    <nav class="max-w-[1280px] mx-auto px-10 py-4 flex flex-col gap-4">
      {navLinks.map((link) => {
        const isActive = pathname === link.href;
        return (
          <a
            href={link.href}
            class={`text-[15px] transition-colors ${isActive ? 'font-semibold text-[#CC4400]' : 'font-light text-[#888078] hover:text-[#1A1A1A]'}`}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  // ── Mobile menu ──
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Theme toggle ──
  const themeBtn = document.getElementById('theme-toggle');
  const moonIcon = document.getElementById('icon-moon');
  const sunIcon = document.getElementById('icon-sun');

  function applyThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    if (moonIcon) moonIcon.style.display = isDark ? 'none' : 'block';
    if (sunIcon)  sunIcon.style.display  = isDark ? 'block' : 'none';
  }

  // Set correct icon on load
  applyThemeIcons();

  themeBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    applyThemeIcons();
  });
</script>
