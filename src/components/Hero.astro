<section class="pt-10 pb-8">
  <h1
    class="text-[96px] leading-[1.03] mb-7 tracking-tight text-center lg:text-left"
    style="font-family: 'DM Serif Display', Georgia, serif;"
  >
    Minh Nguyen.
  </h1>
  <p class="text-[30px] text-[#1A1A1A] mb-5 font-light tracking-tight text-center lg:text-left">
    I build ML systems from zero to production. Fast.
  </p>
  <p class="text-[18px] text-[#4A4540] leading-[1.75] max-w-[660px] mb-6 font-light text-center lg:text-left mx-auto lg:mx-0">
    Machine Learning Engineer with 3+ years at
    <a href="#exp-blackrock" data-expand="exp-blackrock" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">BlackRock</a>,
    <a href="#exp-tesla" data-expand="exp-tesla" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">Tesla</a>, and
    <a href="#exp-homebase" data-expand="exp-homebase" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">Homebase (Y Combinator)</a>.
    Strong foundation in taking ML systems from zero to production — spanning
    <a href="#skills" data-scroll="skills" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">document intelligence</a>,
    <a href="#skills" data-scroll="skills" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">agentic reasoning</a>,
    <a href="#skills" data-scroll="skills" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">RAG pipelines</a>, and
    <a href="#skills" data-scroll="skills" class="hero-link font-semibold text-[#1A1A1A] hover:text-[#CC4400] transition-colors cursor-pointer">real-time data infrastructure</a>.
    I work best in high-ownership teams that value speed, reliability, and end-to-end execution.
  </p>
  <div class="flex flex-col gap-2 text-[14px] text-[#888078] font-light">
    <!-- Specialties row -->
    <div class="flex flex-wrap gap-x-2.5 gap-y-1 items-center justify-center lg:justify-start">
      <!-- CPU / specialty icon -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13" class="shrink-0 text-[#CC4400]">
        <rect x="7" y="7" width="10" height="10" rx="1"/>
        <path d="M7 9H5M7 12H5M7 15H5M17 9h2M17 12h2M17 15h2M9 7V5M12 7V5M15 7V5M9 17v2M12 17v2M15 17v2"/>
      </svg>
      <span>Machine Learning</span><span>·</span>
      <span>Agentic AI</span><span>·</span>
      <span>RAG</span><span>·</span>
      <span>Document Intelligence</span><span>·</span>
      <span>MLOps</span>
    </div>
    <!-- Locations row -->
    <div class="flex flex-wrap gap-x-2.5 gap-y-1 items-center justify-center lg:justify-start">
      <!-- Map pin / location icon -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13" class="shrink-0 text-[#CC4400]">
        <path d="M12 2C8.686 2 6 4.686 6 8c0 4.418 6 12 6 12s6-7.582 6-12c0-3.314-2.686-6-6-6z"/>
        <circle cx="12" cy="8" r="2"/>
      </svg>
      <span>San Francisco</span><span>·</span>
      <span>San Jose</span><span>·</span>
      <span>Seattle</span><span>·</span>
      <span>Redmond</span><span>·</span>
      <span>New York</span><span>·</span>
      <span>Philadelphia</span>
    </div>
  </div>
</section>

<script>
  const OFFSET = 80; // px below the sticky navbar

  function scrollTo(id) {
    const el = document.getElementById(id);
    if (!el) return;
    const top = el.getBoundingClientRect().top + window.pageYOffset - OFFSET;
    window.scrollTo({ top, behavior: 'smooth' });
  }

  function expandExperience(id) {
    const el = document.getElementById(id);
    if (!el) return;
    if (!el.classList.contains('open')) {
      el.classList.add('open');
      const btn = el.querySelector('.experience-toggle');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    }
  }

  document.querySelectorAll('a[data-expand]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const id = (link as HTMLElement).dataset.expand;
      expandExperience(id);
      scrollTo(id);
    });
  });

  document.querySelectorAll('a[data-scroll]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const id = (link as HTMLElement).dataset.scroll;
      scrollTo(id);
    });
  });
</script>
