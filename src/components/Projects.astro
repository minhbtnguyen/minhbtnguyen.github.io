---
import { projects } from '../data/projects.js';
const featured = projects.filter((p) => p.featured);
---

<div>
  <!-- Section label -->
  <div class="flex items-center gap-2 mb-4">
    <div class="w-[3px] h-4 bg-[#CC4400]"></div>
    <span class="text-[13px] font-medium tracking-[0.12em] uppercase text-[#888078]">Spare-time Builds</span>
  </div>

  <!-- Featured project cards -->
  <div class="space-y-3">
    {
      featured.map((p) => (
        <div class="group flex flex-col border border-[#E4DDD4] bg-[#FEFCF8] hover:border-[#C0B5A8] hover:shadow-[0_8px_32px_rgba(0,0,0,0.07)] transition-all duration-300 overflow-hidden p-5">

          <!-- Title + GitHub icon -->
          <div class="flex items-start justify-between gap-2 mb-3">
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[15px] text-[#CC4400] leading-[1.25] hover:underline decoration-[#CC4400]"
              style="font-family:'DM Serif Display',Georgia,serif;"
            >
              {p.name}
            </a>
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#C0B5A8] hover:text-[#CC4400] transition-colors shrink-0 mt-0.5"
              aria-label="View on GitHub"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          </div>

          <!-- Description -->
          <p class="text-[12px] font-light text-[#4A4540] leading-[1.7] mb-4 flex-1">
            {p.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1 mb-4">
            {p.tags.map((tag) => (
              <span class="px-2 py-[3px] text-[10px] font-light text-[#666059] bg-[#F5F2ED] border border-[#E4DDD4] rounded-sm">
                {tag}
              </span>
            ))}
          </div>

          <!-- Footer: award + date -->
          <div class="flex items-center justify-between gap-2 pt-3.5 border-t border-[#EDE8E0]">
            {p.award ? (
              <span class="text-[10px] font-light text-[#888078] italic leading-tight">{p.award}</span>
            ) : (
              <span />
            )}
            <span class="text-[10px] font-light text-[#AAA098] shrink-0 ml-auto">{p.date}</span>
          </div>

        </div>
      ))
    }
  </div>

  <!-- Footer note -->
  <p class="mt-4 text-[11px] font-light text-[#888078] italic leading-[1.6]">
    Built nights and weekends. Day-job production work is in Experience.
  </p>
</div>
