---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Minh Nguyen — I build ML systems from zero to production. Fast.',
  description =
    'ML Engineer with 3+ years building production AI systems at BlackRock, Tesla, and Homebase (YC). Specializing in agentic AI, RAG pipelines, and document intelligence.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Minh Nguyen" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).href} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <!-- Inline: set dark class before first paint to prevent flash -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          if (saved !== 'light') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body
    class="bg-[#FFFDF9] text-[#1A1A1A] antialiased"
    style="font-family: 'DM Sans', system-ui, sans-serif;"
  >
    <div id="cursor-glow" aria-hidden="true"></div>
    <slot />
    <script>
      const items = document.querySelectorAll('[data-animate]');
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      items.forEach((el) => io.observe(el));
    </script>
    <script>
      const glow = document.getElementById('cursor-glow');
      const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (glow && canHover && !reduceMotion) {
        let targetX = 0;
        let targetY = 0;
        let raf: number | null = null;

        const render = () => {
          glow.style.transform = `translate3d(${targetX}px, ${targetY}px, 0)`;
          raf = null;
        };

        window.addEventListener('mousemove', (e) => {
          targetX = e.clientX;
          targetY = e.clientY;
          glow.style.opacity = '1';
          if (raf === null) raf = requestAnimationFrame(render);
        });

        document.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* ============================================================
     DARK MODE — black bg, white/bright-grey/orange text palette
  ============================================================ */

  /* Body */
  html.dark body { background-color: #000000; color: #FFFFFF; }

  /* ── Backgrounds ── */
  html.dark .bg-\[\#FFFDF9\]     { background-color: #000000; }
  html.dark .bg-\[\#FEFCF8\]     { background-color: #0D0D0D; }
  html.dark .bg-white             { background-color: #0D0D0D; }
  html.dark .bg-\[\#F5F2ED\],
  html.dark .bg-\[\#F5F3F0\],
  html.dark .bg-\[\#F0EDE8\]     { background-color: #1A1A1A; }
  html.dark .bg-\[\#EDE8E0\],
  html.dark .bg-\[\#EEE8E0\]     { background-color: #111111; }

  /* Navbar / mobile menu with opacity */
  html.dark .bg-\[\#FFFDF9\]\/50 { background-color: rgb(0 0 0 / 0.6); }
  html.dark .bg-\[\#FFFDF9\]\/95 { background-color: rgb(0 0 0 / 0.95); }

  /* ── Text ── */
  html.dark .text-\[\#1A1A1A\]   { color: #FFFFFF; }
  html.dark .text-\[\#4A4540\]   { color: #CCCCCC; }   /* bright grey */
  html.dark .text-\[\#888078\]   { color: #999999; }   /* mid grey */
  html.dark .text-\[\#666059\]   { color: #BBBBBB; }   /* bright grey */
  html.dark .text-\[\#AAA098\]   { color: #666666; }   /* dim grey */
  html.dark .text-\[\#CCC5BC\]   { color: #333333; }   /* subtle separator */

  /* Hover text */
  html.dark .hover\:text-\[\#1A1A1A\]:hover { color: #FFFFFF; }

  /* ── Borders ── */
  html.dark .border-\[\#DDD5C8\]   { border-color: #2A2A2A; }
  html.dark .border-\[\#E4DDD4\]   { border-color: #222222; }
  html.dark .border-\[\#E8E4DE\]   { border-color: #222222; }
  html.dark .border-\[\#E0D8D0\]   { border-color: #222222; }
  html.dark .border-\[\#EDE8E0\]   { border-color: #1A1A1A; }
  html.dark .border-\[\#EEE8E0\]   { border-color: #1A1A1A; }
  html.dark .border-\[\#C2B8AF\]   { border-color: #333333; }
  html.dark .border-\[\#C8BFB4\]   { border-color: #333333; }
  html.dark .border-\[\#C0B5A8\]   { border-color: #333333; }

  /* Opacity border modifier */
  html.dark .border-\[\#DDD5C8\]\/60 { border-color: rgb(42 42 42 / 0.6); }

  /* ── Divide (Experience / Education accordion) ── */
  html.dark .divide-\[\#EEE8E0\] > :not([hidden]) ~ :not([hidden]) {
    border-color: #1A1A1A;
  }

  /* ── Hover border colors ── */
  html.dark .hover\:border-\[\#C8BFB4\]:hover { border-color: #444444; }
  html.dark .hover\:border-\[\#C0B5A8\]:hover { border-color: #444444; }

  /* ── Card hover shadow ── */
  html.dark .hover\:shadow-\[0_8px_32px_rgba\(0\,0\,0\,0\.07\)\]:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  /* ── Logo mark border (inline style override) ── */
  html.dark header a[aria-label="Home"] > div {
    border-color: #333333 !important;
  }

  /* ── Company / school logo images — white bg + rounded square in dark mode ── */
  html.dark .logo-box {
    background-color: #FFFFFF !important;
    border-radius: 6px !important;
    overflow: hidden !important;
  }
  html.dark .logo-box img {
    background-color: #FFFFFF !important;
    mix-blend-mode: normal !important;
  }

  /* ── Email button in dark mode: orange fill + white text ── */
  html.dark .contact-email {
    background-color: #CC4400 !important;
    color: #FFFFFF !important;
    border-color: #CC4400 !important;
  }

  /* ── Fix hover effects blocked by dark mode specificity ──
     html.dark .xxx has specificity (0,2,1) which beats Tailwind
     hover classes at (0,2,0). Explicit overrides with !important fix this. */
  html.dark .hover\:text-\[\#CC4400\]:hover     { color: #CC4400 !important; }
  html.dark .hover\:bg-\[\#CC4400\]:hover       { background-color: #CC4400 !important; }
  html.dark .hover\:text-white:hover            { color: #FFFFFF !important; }
  html.dark .hover\:border-\[\#CC4400\]:hover   { border-color: #CC4400 !important; }
  html.dark .hover\:decoration-\[\#CC4400\]:hover { text-decoration-color: #CC4400 !important; }

  /* ============================================================
     ENTRANCE ANIMATIONS — fade + slide up when scrolled into view
  ============================================================ */
  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  [data-animate].in-view {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-animate] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* ============================================================
     CURSOR GLOW — orange radial highlight that follows the mouse
  ============================================================ */
  #cursor-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 600px;
    height: 600px;
    margin-left: -300px;
    margin-top: -300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(204, 68, 0, 0.07) 0%, rgba(204, 68, 0, 0) 70%);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    will-change: transform;
  }

  html.dark #cursor-glow {
    background: radial-gradient(circle, rgba(204, 68, 0, 0.22) 0%, rgba(204, 68, 0, 0) 70%);
  }

  /* Keep page content above the glow */
  body > :not(#cursor-glow) {
    position: relative;
    z-index: 1;
  }
</style>
