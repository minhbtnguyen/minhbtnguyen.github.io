---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageFooter from '../components/PageFooter.astro';

const entries = [
  {
    date: 'May 22, 2026',
    title: 'Mini auto-gradient from scratch',
    description:
      'Understand what PyTorch does under the hood by building the API and components of an MLP in pure Python.',
    href: 'https://github.com/minhbtnguyen',
  },
];
---

<Layout title="Distillation — Minh Nguyen" description="First principles distilled from research by Minh Nguyen.">
  <div class="min-h-screen flex flex-col">
    <Navbar />

    <div class="flex-1 max-w-[820px] mx-auto px-10 pt-16 pb-10 w-full">
      <!-- Page heading -->
      <div class="mb-12 text-center">
        <p class="text-[14px] font-medium tracking-[0.2em] uppercase text-[#CC4400] mb-3">Distillation</p>
        <h1
          class="text-[34px] text-[#1A1A1A] tracking-tight leading-[1.1]"
          style="font-family:'DM Serif Display',Georgia,serif;font-style:italic;"
        >
          First principles distilled from research
        </h1>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-[18px] top-0 bottom-0 w-px bg-[#E4DDD4]"></div>

        <div class="space-y-10">
          {
            entries.map((entry) => (
              <div class="relative pl-14">
                <!-- Circle dot -->
                <div class="absolute left-[13px] top-[3px] w-[11px] h-[11px] rounded-full border border-[#C8BFB4] bg-[#FFFDF9]"></div>

                <!-- Date -->
                <p class="text-[12px] font-light text-[#CC4400] tracking-[0.06em] mb-2">
                  {entry.date}
                </p>

                <!-- Entry card -->
                <div class="border border-[#E4DDD4] bg-white p-5 hover:border-[#C8BFB4] transition-colors">
                  <h2 class="text-[16px] font-medium text-[#1A1A1A] mb-2">{entry.title}</h2>
                  <p class="text-[14px] font-light text-[#4A4540] leading-[1.7] mb-4">
                    {entry.description}
                  </p>
                  <a
                    href={entry.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block text-[#666059] hover:text-[#CC4400] transition-colors"
                    aria-label="View on GitHub"
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="max-w-[820px] mx-auto px-10 pb-10 w-full">
      <PageFooter />
    </div>
  </div>
</Layout>
