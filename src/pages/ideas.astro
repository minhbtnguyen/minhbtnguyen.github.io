---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageFooter from '../components/PageFooter.astro';
import { projects } from '../data/projects.js';
---

<Layout title="Minh's Ideas — Minh Nguyen" description="Original projects and ideas by Minh Nguyen.">
  <div class="min-h-screen flex flex-col">
    <Navbar />

    <div class="flex-1 max-w-[1200px] mx-auto px-10 pt-16 pb-10 w-full">
      <!-- Page heading -->
      <div class="mb-12 text-center">
        <p class="text-[14px] font-medium tracking-[0.2em] uppercase text-[#CC4400] mb-3">Minh's Ideas</p>
        <h1
          class="text-[34px] text-[#1A1A1A] tracking-tight leading-[1.1]"
          style="font-family:'DM Serif Display',Georgia,serif;font-style:italic;"
        >
          My original ideas
        </h1>
      </div>

      <!-- 3-column grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          projects.map((p) => (
            <article class="project-card group flex flex-col border border-[#E4DDD4] bg-[#FEFCF8] hover:shadow-[0_8px_32px_rgba(0,0,0,0.07)] overflow-hidden">

              <!-- Screenshot image — 16:9 aspect ratio -->
              <div class="relative overflow-hidden bg-[#EDE8E0]" style="aspect-ratio:16/9;">
                <img
                  src={p.imageSrc}
                  alt={p.name}
                  class="absolute inset-0 w-full h-full object-cover object-top group-hover:scale-[1.03] transition-transform duration-500"
                  onerror="this.style.display='none'"
                />
                {p.featured && (
                  <div class="absolute top-3 right-3">
                    <svg viewBox="0 0 24 24" fill="#CC4400" width="18" height="18">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  </div>
                )}
              </div>

              <!-- Content -->
              <div class="flex flex-col flex-1 p-5">

                <!-- Title + GitHub icon -->
                <div class="flex items-start justify-between gap-2 mb-3">
                  <h2
                    class="text-[17px] text-[#CC4400] leading-[1.25]"
                    style="font-family:'DM Serif Display',Georgia,serif;"
                  >
                    {p.name}
                  </h2>
                  <a
                    href={p.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#C0B5A8] hover:text-[#CC4400] transition-colors shrink-0 mt-0.5"
                    aria-label="View on GitHub"
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                </div>

                <!-- Description -->
                <p class="text-[13px] font-light text-[#4A4540] leading-[1.7] mb-4 flex-1">
                  {p.description}
                </p>

                <!-- Tags -->
                <div class="flex flex-wrap gap-1 mb-4">
                  {p.tags.map((tag) => (
                    <span class="px-2 py-[3px] text-[10px] font-light text-[#666059] bg-[#F5F2ED] border border-[#E4DDD4] rounded-sm">
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Footer: award + date -->
                <div class="flex items-center justify-between gap-2 pt-3.5 border-t border-[#EDE8E0]">
                  {p.award ? (
                    <span class="text-[10px] font-light text-[#888078] italic leading-tight">{p.award}</span>
                  ) : (
                    <span />
                  )}
                  <span class="text-[10px] font-light text-[#AAA098] shrink-0 ml-auto">{p.date}</span>
                </div>

              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-10 pb-10 w-full">
      <PageFooter />
    </div>
  </div>
</Layout>

<style>
  @keyframes borderPulse {
    0%, 100% { border-color: #E4DDD4; }
    50%       { border-color: #CC4400; }
  }

  .project-card {
    animation: borderPulse 3s ease-in-out infinite;
  }

  .project-card:nth-child(2) { animation-delay: 1s; }
  .project-card:nth-child(3) { animation-delay: 2s; }
  .project-card:nth-child(4) { animation-delay: 0.5s; }
  .project-card:nth-child(5) { animation-delay: 1.5s; }
  .project-card:nth-child(6) { animation-delay: 2.5s; }

  .project-card:hover {
    animation: none;
    border-color: #CC4400;
    transition: border-color 0.3s ease;
  }
</style>
